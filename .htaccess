# StockMarketWave - Hostinger (LiteSpeed) performance config
# Handles canonical redirects, compression, browser caching, and MIME types.

# ----------------------------------------------------------------------
# 0) Canonical host + scheme (single 301 hop to https://stockmarketwave.com)
#    Consolidates duplicate signals so Google indexes one canonical URL.
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS and drop the www. prefix in a single redirect
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^ https://stockmarketwave.com%{REQUEST_URI} [L,R=301]

    # Redirect /index.html to the root so "/" is the only home URL
    RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
    RewriteRule ^index\.html$ / [L,R=301]
</IfModule>

# ----------------------------------------------------------------------
# 1) Compression (gzip via mod_deflate; LiteSpeed serves Brotli when enabled)
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# 2) Browser caching (Expires headers)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML: revalidate often so content updates show up quickly
    ExpiresByType text/html "access plus 0 seconds"

    # CSS / JS: safe to cache long-term because URLs are version-busted (?v=)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Images / icons / fonts
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"

    # Manifest and data
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
</IfModule>

# ----------------------------------------------------------------------
# 3) Explicit Cache-Control (belt-and-suspenders alongside Expires)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(png|jpe?g|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=15552000"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# 4) Correct MIME types
# ----------------------------------------------------------------------
<IfModule mod_mime.c>
    AddType image/svg+xml .svg
    AddType application/manifest+json .webmanifest
    AddType application/json .json
</IfModule>
